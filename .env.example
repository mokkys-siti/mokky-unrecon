# ---------------------------------------------------------------------------
# Mokky's Unrecon — environment template. Copy to .env.local and fill in.
# NEVER commit .env.local. Values below are placeholders only.
# Find these in the Supabase dashboard: Project Settings → API.
# ---------------------------------------------------------------------------

# Public (safe to expose to the browser) — used by the app's client + server code.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Server-only. Bypasses RLS — used ONLY by the user-seed script and to create
# RLS test fixtures. Never import this into any file under src/.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- Tooling-only (not read by the Next.js app) --------------------------
# Personal access token for the Supabase CLI (Account → Access Tokens),
# used by `supabase link`. Alternatively run `supabase login` interactively.
SUPABASE_ACCESS_TOKEN=YOUR_CLI_ACCESS_TOKEN

# Database password for `supabase db push` / direct connections.
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# Vercel CLI access token (https://vercel.com/account/tokens), used for
# `vercel link` / `vercel deploy`. Tooling-only; not read by the app.
VERCEL_TOKEN=YOUR_VERCEL_TOKEN
